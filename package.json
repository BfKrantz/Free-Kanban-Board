{
  "name": "kanban-app",
  "version": "0.1.0",
  "private": true,
  "homepage": ".",

  "main": "main.js",

  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },

  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2"
  },

  "scripts": {
    "dev": "concurrently \"react-scripts start\" \"electron .\"",
    "build": "react-scripts build",
    "electron": "electron .",
    "dist": "npm run build && electron-builder",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },

  
  "build": {
    "extends": null,
    "appId": "com.trey.kanbanboard",
    "productName": "Kanban Board",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "main.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "forceCodeSigning": false
    }
  },

  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },

  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}